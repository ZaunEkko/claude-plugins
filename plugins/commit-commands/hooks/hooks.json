{
  "description": "Prevents Claude Code Bash and Playwright unsafe process execution from bypassing dynamic commit attribution, and captures per-session model metadata.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|mcp__.*playwright.*__browser_run_code_unsafe",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/scripts/deny-direct-git-commit.mjs"
            ],
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/capture-session-model.mjs\" start",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/capture-session-model.mjs\" end",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
